---
import Layout from '../layouts/Layout.astro';
import logo from '../images/logo-harpuia.png';
---

<Layout title="La escuela de las ranitas ninja">
	<header>
		<div class="flex justify-center items-center">
			<img src={logo} alt="Escuela de las ranitas ninja" class="max-w-xl"/>
		</div>
	</header>
	<main>
		<!--REDES Y LINKS -->
		<div class="flex justify-center">
			<!--TWITCH-->
			<a href="https://www.twitch.tv/zetsubou_harpuia" target="_blank">
				<button
					type="button"
					data-te-ripple-init
					data-te-ripple-color="light"
					class="m-2 inline-block rounded-full p-3 text-xs font-medium uppercase leading-normal text-white shadow-md transition duration-150 ease-in-out hover:shadow-lg focus:shadow-lg focus:outline-none focus:ring-0 active:shadow-lg"
					style="background-color: #9146ff">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-4 w-4"
						fill="currentColor"
						viewBox="0 0 24 24">
						<path
						d="M2.149 0l-1.612 4.119v16.836h5.731v3.045h3.224l3.045-3.045h4.657l6.269-6.269v-14.686h-21.314zm19.164 13.612l-3.582 3.582h-5.731l-3.045 3.045v-3.045h-4.836v-15.045h17.194v11.463zm-3.582-7.343v6.262h-2.149v-6.262h2.149zm-5.731 0v6.262h-2.149v-6.262h2.149z"
						fill-rule="evenodd"
						clip-rule="evenodd" />
					</svg>
				</button>
			</a>
			<!--FIN TWITCH -->
			<!-- TWITTER -->
			<a href="https://twitter.com/harpuiaVT" target="_blank">
				<button
					type="button"
					data-te-ripple-init
					data-te-ripple-color="light"
					class="m-2 inline-block rounded-full p-3 text-xs font-medium uppercase leading-normal text-white shadow-md transition duration-150 ease-in-out hover:shadow-lg focus:shadow-lg focus:outline-none focus:ring-0 active:shadow-lg"
					style="background-color: #1da1f2">
					<svg
					xmlns="http://www.w3.org/2000/svg"
					class="h-4 w-4"
					fill="currentColor"
					viewBox="0 0 24 24">
					<path
						d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z" />
					</svg>
				</button>
			</a>
			<!--FIN TWITTER -->
		</div>
	</main>
	<footer class="fixed inset-x-0 bottom-0 text-center">
		<p id="contact"></p>
		<p id="by"></p>
	</footer>
	<script>
		console.log('Si estás leyendo esto tkm')
		const ob = 'emV0c3Vib3UuaGFycHVpYUBnbWFpbC5jb20';
		const contact = document.getElementById('contact');
		const by = document.getElementById('by'); 
		contact.textContent = 'Contacto - ' + atob(ob);
		by.textContent = 'Creado por Harpuia - ' + new Date().getFullYear();

	</script>
</Layout>

<style>
	main {
		margin: auto;
		padding: 1.5rem;
		max-width: 60ch;
	}
</style>
